model PurchaseRequest {
  id                      String                @id @default(uuid())
  createdAt               DateTime              @default(now())
  purchaseRequestNumber   Int                   @default(0)
  supplier                Supplier              @relation(fields: [supplierId], references: [id])
  supplierId              String
  status                  PurchaseRequestStatus @default(DRAFT)
  remark                  String?
  expectedDeliveryDate    DateTime?
  approvedDate            DateTime?
  approvedBy              User?                 @relation("ApprovedBy", fields: [approvedById], references: [id])
  approvedById            String?
  orderedDate             DateTime?
  receivedDate            DateTime?
  isEnabled               Boolean               @default(true)
  enableRemark            String?
  enabledBy               User?                 @relation("EnabledBy", fields: [enabledById], references: [id])
  enabledById             String?
  disableRemark           String?
  disabledBy              User?                 @relation("DisabledBy", fields: [disabledById], references: [id])
  disabledById            String?
  disabledDate            DateTime?
  PurchaseRequestItem     PurchaseRequestItem[]
}

model PurchaseRequestItem {
  id                    String          @id @default(uuid())
  createdAt             DateTime        @default(now())
  purchaseRequest       PurchaseRequest @relation(fields: [purchaseRequestId], references: [id])
  purchaseRequestId     String
  productVariant        ProductVariant  @relation(fields: [productVariantId], references: [id])
  productVariantId      String
  requestedQuantity     Int
  receivedQuantity      Int             @default(0)
  expectedUnitPrice     Float?
  currency              String?
  remark                String?
  isEnabled             Boolean         @default(true)
  enableRemark          String?
  enabledBy             User?           @relation("EnabledBy", fields: [enabledById], references: [id])
  enabledById           String?
  disableRemark         String?
  disabledBy            User?           @relation("DisabledBy", fields: [disabledById], references: [id])
  disabledById          String?
  disabledDate          DateTime?
}
