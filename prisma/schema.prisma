generator client {
  provider        = "prisma-client-js"
  log             = ["query", "info", "warn", "error"]
}
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

enum OrderStatus {
  PENDING_APPROVAL
  DENIED
  PENDING_FULFILLMENT
  PARTIALLY_FULFILLED
  PENDING_SHIPMENT
  PARTIALLY_SHIPPED
  SHIPPED
  DELIVERED
  COMPLETED
  CANCELLED
}

enum PurchaseRequestStatus {
  DRAFT
  PENDING_APPROVAL
  APPROVED
  ORDERED
  PARTIALLY_RECEIVED
  RECEIVED
  REJECTED
  CANCELLED
}

enum ShipmentType {
  ORDER
  TRANSFER
}

model User {
  id                                 String                     @id @default(uuid())
  createdAt                          DateTime                   @default(now())
  name                               String
  phoneNumber                        String?
  email                              String
  password                           String
  isEnabled                          Boolean                    @default(true)
  enableRemark                       String?
  enabledBy                          User?                      @relation("EnabledBy", fields: [enabledById], references: [id])
  enabledById                        String?
  disableRemark                      String?
  disabledBy                         User?                      @relation("DisabledBy", fields: [disabledById], references: [id])
  disabledById                       String?
  disabledDate                       DateTime?
  userRoles                          UserRole[]
  RoleEnabledBy                      Role[]                     @relation("EnabledBy")
  RoleDisabledBy                     Role[]                     @relation("DisabledBy")
  UserRoleDisabledBy                 UserRole[]                 @relation("DisabledBy")
  UserRoleEnabledBy                  UserRole[]                 @relation("EnabledBy")
  UserEnabledBy                      User[]                     @relation("EnabledBy")
  UserDisabledBy                     User[]                     @relation("DisabledBy")
  PaymentOptionEnabledBy             PaymentOption[]            @relation("EnabledBy")
  PaymentOptionDisabledBy            PaymentOption[]            @relation("DisabledBy")
  BankEnabledBy                      Bank[]                     @relation("EnabledBy")
  BankDisabledBy                     Bank[]                     @relation("DisabledBy")
  BrandEnabledBy                     Brand[]                    @relation("EnabledBy")
  BrandDisabledBy                    Brand[]                    @relation("DisabledBy")
  LocationEnabledBy                  Location[]                 @relation("EnabledBy")
  LocationDisabledBy                 Location[]                 @relation("DisabledBy")
  TypeOfProductEnabledBy             TypeOfProduct[]            @relation("EnabledBy")
  TypeOfProductDisabledBy            TypeOfProduct[]            @relation("DisabledBy")
  CustomerEnabledBy                  Customer[]                 @relation("EnabledBy")
  CustomerDisabledBy                 Customer[]                 @relation("DisabledBy")
  ProductEnabledBy                   Product[]                  @relation("EnabledBy")
  ProductDisabledBy                  Product[]                  @relation("DisabledBy")
  ProductVariantEnabledBy            ProductVariant[]           @relation("EnabledBy")
  ProductVariantDisabledBy           ProductVariant[]           @relation("DisabledBy")
  SupplierEnabledBy                  Supplier[]                 @relation("EnabledBy")
  SupplierDisabledBy                 Supplier[]                 @relation("DisabledBy")
  StockSourceEnabledBy               StockSource[]              @relation("EnabledBy")
  StockSourceDisabledBy              StockSource[]              @relation("DisabledBy")
  ProductVariantAttributeEnabledBy   ProductVariantAttribute[]  @relation("EnabledBy")
  ProductVariantAttributeDisabledBy  ProductVariantAttribute[]  @relation("DisabledBy")
  ProductVariantPriceEnabledBy       ProductVariantPrice[]      @relation("EnabledBy")
  ProductVariantPriceDisabledBy      ProductVariantPrice[]      @relation("DisabledBy")
  StockEnabledBy                     Stock[]                    @relation("EnabledBy")
  StockDisabledBy                    Stock[]                    @relation("DisabledBy")
  OrderEnabledBy                     Order[]                    @relation("EnabledBy")
  OrderDisabledBy                    Order[]                    @relation("DisabledBy")
  OrderItemEnabledBy                 OrderItem[]                @relation("EnabledBy")
  OrderItemDisabledBy                OrderItem[]                @relation("DisabledBy")
  OrderItemApprovedBy                OrderItem[]                @relation("ApprovedBy")
  OrderPaymentEnabledBy              OrderPayment[]             @relation("EnabledBy")
  OrderPaymentDisabledBy             OrderPayment[]             @relation("DisabledBy")
  // OrderItemTransactionTransferredBy    OrderItemTransaction[]       @relation("TransferredBy")
  // OrderItemTransactionReceivedBy       OrderItemTransaction[]       @relation("ReceivedBy")
  PaymentEnabledBy                   Payment[]                  @relation("EnabledBy")
  PaymentDisabledBy                  Payment[]                  @relation("DisabledBy")
  // OrderItemTransactionDetailEnabledBy  OrderItemTransactionDetail[] @relation("EnabledBy")
  // OrderItemTransactionDetailDisabledBy OrderItemTransactionDetail[] @relation("DisabledBy")
  // OrderItemTransactionEnabledBy        OrderItemTransaction[]       @relation("EnabledBy")
  // OrderItemTransactionDisabledBy       OrderItemTransaction[]       @relation("DisabledBy")
  OrderItemFulfillmentEnabledBy      OrderItemFulfillment[]     @relation("EnabledBy")
  OrderItemFulfillmentDisabledBy     OrderItemFulfillment[]     @relation("DisabledBy")
  ShipmentStatusOptionEnabledBy      ShipmentStatusOption[]     @relation("EnabledBy")
  ShipmentStatusOptionDisabledBy     ShipmentStatusOption[]     @relation("DisabledBy")
  ShipmentItemStatusOptionEnabledBy  ShipmentItemStatusOption[] @relation("EnabledBy")
  ShipmentItemStatusOptionDisabledBy ShipmentItemStatusOption[] @relation("DisabledBy")
  CarrierTypeEnabledBy               CarrierType[]              @relation("EnabledBy")
  CarrierTypeDisabledBy              CarrierType[]              @relation("DisabledBy")
  CarrierEnabledBy                   Carrier[]                  @relation("EnabledBy")
  CarrierDisabledBy                  Carrier[]                  @relation("DisabledBy")
  ShipmentEnabledBy                  Shipment[]                 @relation("EnabledBy")
  ShipmentDisabledBy                 Shipment[]                 @relation("DisabledBy")
  ShipmentItemEnabledBy              ShipmentItem[]             @relation("EnabledBy")
  ShipmentItemDisabledBy             ShipmentItem[]             @relation("DisabledBy")
  ShipmentStatusEnabledBy            ShipmentStatus[]           @relation("EnabledBy")
  ShipmentStatusDisabledBy           ShipmentStatus[]           @relation("DisabledBy")
  ShipmentItemStatusEnabledBy        ShipmentItemStatus[]       @relation("EnabledBy")
  ShipmentItemStatusDisabledBy       ShipmentItemStatus[]       @relation("DisabledBy")
  ShipmentStartedBy                  Shipment[]                 @relation("StartedBy")
  ShipmentArrivalConfirmedBy         Shipment[]                 @relation("ArrivalConfirmedBy")
  ShipmentLoadedBy                   Shipment[]                 @relation("LoadedBy")
  ShipmentCompletedBy                Shipment[]                 @relation("CompletedBy")
  BankAccountEnabledBy               BankAccount[]              @relation("EnabledBy")
  BankAccountDisabledBy              BankAccount[]              @relation("DisabledBy")
  StockDiscardReasonEnabledBy        StockDiscardReason[]       @relation("EnabledBy")
  StockDiscardReasonDisabledBy       StockDiscardReason[]       @relation("DisabledBy")
  DiscardedStockEnabledBy            DiscardedStock[]           @relation("EnabledBy")
  DiscardedStockDisabledBy           DiscardedStock[]           @relation("DisabledBy")
  StockTransactionItemEnabledBy      StockTransactionItem[]     @relation("EnabledBy")
  StockTransactionItemDisabledBy     StockTransactionItem[]     @relation("DisabledBy")
  PurchaseRequestEnabledBy           PurchaseRequest[]          @relation("EnabledBy")
  PurchaseRequestDisabledBy          PurchaseRequest[]          @relation("DisabledBy")
  PurchaseRequestApprovedBy          PurchaseRequest[]          @relation("ApprovedBy")
  PurchaseRequestItemEnabledBy       PurchaseRequestItem[]      @relation("EnabledBy")
  PurchaseRequestItemDisabledBy      PurchaseRequestItem[]      @relation("DisabledBy")
}

model UserRole {
  id            String    @id @default(uuid())
  createdAt     DateTime  @default(now())
  user          User      @relation(fields: [userId], references: [id])
  userId        String
  role          Role      @relation(fields: [roleId], references: [id])
  roleId        String
  isEnabled     Boolean   @default(true)
  disableRemark String?
  disabledBy    User?     @relation("DisabledBy", fields: [disabledById], references: [id])
  disabledById  String?
  disabledDate  DateTime?
  enableRemark  String?
  enabledBy     User?     @relation("EnabledBy", fields: [enabledById], references: [id])
  enabledById   String?
}

model Role {
  id            String     @id @default(uuid())
  createdAt     DateTime   @default(now())
  title         String
  permissions   String
  isEnabled     Boolean    @default(true)
  enableRemark  String?
  enabledBy     User?      @relation("EnabledBy", fields: [enabledById], references: [id])
  enabledById   String?
  disableRemark String?
  disabledBy    User?      @relation("DisabledBy", fields: [disabledById], references: [id])
  disabledById  String?
  disabledDate  DateTime?
  UserRole      UserRole[]
}

model PaymentOption {
  id            String    @id @default(uuid())
  createdAt     DateTime  @default(now())
  title         String
  abbreviation  String?
  description   String?
  isEnabled     Boolean   @default(true)
  enableRemark  String?
  enabledBy     User?     @relation("EnabledBy", fields: [enabledById], references: [id])
  enabledById   String?
  disableRemark String?
  disabledBy    User?     @relation("DisabledBy", fields: [disabledById], references: [id])
  disabledById  String?
  disabledDate  DateTime?
  Order         Order[]
  // OrderPayment OrderPayment[]
  Payment       Payment[]
}

model Bank {
  id            String        @id @default(uuid())
  createdAt     DateTime      @default(now())
  title         String
  abbreviation  String?
  description   String?
  isEnabled     Boolean       @default(true)
  enableRemark  String?
  enabledBy     User?         @relation("EnabledBy", fields: [enabledById], references: [id])
  enabledById   String?
  disableRemark String?
  disabledBy    User?         @relation("DisabledBy", fields: [disabledById], references: [id])
  disabledById  String?
  disabledDate  DateTime?
  // Order         Order[]
  // OrderPayment OrderPayment[]
  // Payment       Payment[]
  BankAccount   BankAccount[]
}

model BankAccount {
  id            String    @id @default(uuid())
  createdAt     DateTime  @default(now())
  bank          Bank      @relation(fields: [bankId], references: [id])
  bankId        String
  accountNumber String
  accountName   String
  isEnabled     Boolean   @default(true)
  enableRemark  String?
  enabledBy     User?     @relation("EnabledBy", fields: [enabledById], references: [id])
  enabledById   String?
  disableRemark String?
  disabledBy    User?     @relation("DisabledBy", fields: [disabledById], references: [id])
  disabledById  String?
  disabledDate  DateTime?
  Order         Order[]
  Payment       Payment[]
}

model Brand {
  id             String           @id @default(uuid())
  createdAt      DateTime         @default(now())
  title          String
  abbreviation   String?
  description    String?
  isEnabled      Boolean          @default(true)
  enableRemark   String?
  enabledBy      User?            @relation("EnabledBy", fields: [enabledById], references: [id])
  enabledById    String?
  disableRemark  String?
  disabledBy     User?            @relation("DisabledBy", fields: [disabledById], references: [id])
  disabledById   String?
  disabledDate   DateTime?
  ProductVariant ProductVariant[]
}

model Location {
  id            String    @id @default(uuid())
  createdAt     DateTime  @default(now())
  title         String
  abbreviation  String?
  description   String?
  isEnabled     Boolean   @default(true)
  enableRemark  String?
  enabledBy     User?     @relation("EnabledBy", fields: [enabledById], references: [id])
  enabledById   String?
  disableRemark String?
  disabledBy    User?     @relation("DisabledBy", fields: [disabledById], references: [id])
  disabledById  String?
  disabledDate  DateTime?
  Stock         Stock[]
  shipmentsFrom Shipment[] @relation("ShipmentFromLocation")
  shipmentsTo   Shipment[] @relation("ShipmentToLocation")
  // tranferredFromOrderItemTransaction OrderItemTransaction[] @relation("TransferredFrom")
  // receivedFromOrderItemTransaction   OrderItemTransaction[] @relation("ReceivedFrom")
}

model TypeOfProduct {
  id            String    @id @default(uuid())
  createdAt     DateTime  @default(now())
  title         String
  abbreviation  String?
  description   String?
  isEnabled     Boolean   @default(true)
  enableRemark  String?
  enabledBy     User?     @relation("EnabledBy", fields: [enabledById], references: [id])
  enabledById   String?
  disableRemark String?
  disabledBy    User?     @relation("DisabledBy", fields: [disabledById], references: [id])
  disabledById  String?
  disabledDate  DateTime?
  Product       Product[]
}

model Customer {
  id            String    @id @default(uuid())
  createdAt     DateTime  @default(now())
  name          String
  phoneNumber   String
  tin           String?
  address       String
  isEnabled     Boolean   @default(true)
  enableRemark  String?
  enabledBy     User?     @relation("EnabledBy", fields: [enabledById], references: [id])
  enabledById   String?
  disableRemark String?
  disabledBy    User?     @relation("DisabledBy", fields: [disabledById], references: [id])
  disabledById  String?
  disabledDate  DateTime?
  Order         Order[]
  Payment       Payment[]
}

model Product {
  id              String           @id @default(uuid())
  createdAt       DateTime         @default(now())
  typeOfProduct   TypeOfProduct    @relation(fields: [typeOfProductId], references: [id])
  typeOfProductId String
  title           String
  abbreviation    String?
  description     String?
  isEnabled       Boolean          @default(true)
  enableRemark    String?
  enabledBy       User?            @relation("EnabledBy", fields: [enabledById], references: [id])
  enabledById     String?
  disableRemark   String?
  disabledBy      User?            @relation("DisabledBy", fields: [disabledById], references: [id])
  disabledById    String?
  disabledDate    DateTime?
  ProductVariant  ProductVariant[]
}

model ProductVariant {
  id                      String                    @id @default(uuid())
  createdAt               DateTime                  @default(now())
  product                 Product                   @relation(fields: [productId], references: [id])
  productId               String
  code                    String
  isEnabled               Boolean                   @default(true)
  enableRemark            String?
  enabledBy               User?                     @relation("EnabledBy", fields: [enabledById], references: [id])
  enabledById             String?
  disableRemark           String?
  disabledBy              User?                     @relation("DisabledBy", fields: [disabledById], references: [id])
  disabledById            String?
  disabledDate            DateTime?
  brand                   Brand                     @relation(fields: [brandId], references: [id])
  brandId                 String
  ProductVariantAttribute ProductVariantAttribute[]
  ProductVariantPrice     ProductVariantPrice[]
  Stock                   Stock[]
  OrderItem               OrderItem[]
  PurchaseRequestItem     PurchaseRequestItem[]
}

model Supplier {
  id            String    @id @default(uuid())
  createdAt     DateTime  @default(now())
  title         String
  abbreviation  String?
  description   String?
  isEnabled     Boolean   @default(true)
  enableRemark  String?
  enabledBy     User?     @relation("EnabledBy", fields: [enabledById], references: [id])
  enabledById   String?
  disableRemark String?
  disabledBy    User?     @relation("DisabledBy", fields: [disabledById], references: [id])
  disabledById  String?
  disabledDate       DateTime?
  Stock              Stock[]
  PurchaseRequest    PurchaseRequest[]
}

model StockSource {
  id            String    @id @default(uuid())
  createdAt     DateTime  @default(now())
  title         String
  abbreviation  String?
  description   String?
  isEnabled     Boolean   @default(true)
  enableRemark  String?
  enabledBy     User?     @relation("EnabledBy", fields: [enabledById], references: [id])
  enabledById   String?
  disableRemark String?
  disabledBy    User?     @relation("DisabledBy", fields: [disabledById], references: [id])
  disabledById  String?
  disabledDate  DateTime?
  Stock         Stock[]
}

model ProductVariantAttribute {
  id               String         @id @default(uuid())
  createdAt        DateTime       @default(now())
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id])
  productVariantId String
  key              String
  value            String
  isEnabled        Boolean        @default(true)
  enableRemark     String?
  enabledBy        User?          @relation("EnabledBy", fields: [enabledById], references: [id])
  enabledById      String?
  disableRemark    String?
  disabledBy       User?          @relation("DisabledBy", fields: [disabledById], references: [id])
  disabledById     String?
  disabledDate     DateTime?
}

model ProductVariantPrice {
  id               String         @id @default(uuid())
  createdAt        DateTime       @default(now())
  listPrice        Float
  currency         String
  tag              String?
  productVariant   ProductVariant @relation(fields: [productVariantId], references: [id])
  productVariantId String
  isEnabled        Boolean        @default(true)
  enableRemark     String?
  enabledBy        User?          @relation("EnabledBy", fields: [enabledById], references: [id])
  enabledById      String?
  disableRemark    String?
  disabledBy       User?          @relation("DisabledBy", fields: [disabledById], references: [id])
  disabledById     String?
  disabledDate     DateTime?
  OrderItem        OrderItem[]
}

model Stock {
  id                   String                 @id @default(uuid())
  createdAt            DateTime               @default(now())
  productVariant       ProductVariant         @relation(fields: [productVariantId], references: [id])
  productVariantId     String
  supplier             Supplier               @relation(fields: [supplierId], references: [id])
  supplierId           String
  location             Location               @relation(fields: [locationId], references: [id])
  locationId           String
  batchId              String
  totalPurchasedUnits  Int
  remainingUnits       Int
  manufacturedDate     DateTime?
  expirationDate       DateTime?
  referenceNumber      String?
  receiptNumber        String?
  stockSource          StockSource            @relation(fields: [stockSourceId], references: [id])
  stockSourceId        String
  isEnabled            Boolean                @default(true)
  enableRemark         String?
  enabledBy            User?                  @relation("EnabledBy", fields: [enabledById], references: [id])
  enabledById          String?
  disableRemark        String?
  disabledBy           User?                  @relation("DisabledBy", fields: [disabledById], references: [id])
  disabledById         String?
  disabledDate         DateTime?
  transportationFree   Float
  taxFee               Float
  miscellaneousFee     Float
  purchasePrice        Float
  expectedRetailPrice  Float
  OrderItemFulfillment OrderItemFulfillment[]
  DiscardedStock       DiscardedStock[]
  StockTransactionItem StockTransactionItem[]
  ShipmentItem         ShipmentItem[]
}

model StockDiscardReason {
  id             String           @id @default(uuid())
  createdAt      DateTime         @default(now())
  title          String
  abbreviation   String?
  description    String?
  isEnabled      Boolean          @default(true)
  enableRemark   String?
  enabledBy      User?            @relation("EnabledBy", fields: [enabledById], references: [id])
  enabledById    String?
  disableRemark  String?
  disabledBy     User?            @relation("DisabledBy", fields: [disabledById], references: [id])
  disabledById   String?
  disabledDate   DateTime?
  DiscardedStock DiscardedStock[]
}

model DiscardedStock {
  id                String             @id @default(uuid())
  createdAt         DateTime           @default(now())
  stock             Stock              @relation(fields: [stockId], references: [id])
  stockId           String
  discardedReason   StockDiscardReason @relation(fields: [discardedReasonId], references: [id])
  discardedReasonId String
  quantity          Int
  isEnabled         Boolean            @default(true)
  enableRemark      String?
  enabledBy         User?              @relation("EnabledBy", fields: [enabledById], references: [id])
  enabledById       String?
  disableRemark     String?
  disabledBy        User?              @relation("DisabledBy", fields: [disabledById], references: [id])
  disabledById      String?
  disabledDate      DateTime?
}

model StockTransactionItem {
  id            String    @id @default(uuid())
  createdAt     DateTime  @default(now())
  stock         Stock     @relation(fields: [stockId], references: [id])
  stockId       String
  quantity      Int
  isEnabled     Boolean   @default(true)
  enableRemark  String?
  enabledBy     User?     @relation("EnabledBy", fields: [enabledById], references: [id])
  enabledById   String
  disableRemark String?
  disabledBy    User?     @relation("DisabledBy", fields: [disabledById], references: [id])
  disabledById  String?
  disabledDate  DateTime?
}

model Order {
  id                    String         @id @default(uuid())
  createdAt             DateTime       @default(now())
  customer              Customer       @relation(fields: [customerId], references: [id])
  customerId            String
  paymentOption         PaymentOption  @relation(fields: [paymentOptionId], references: [id])
  paymentOptionId       String
  paymentOptionRefernce String?
  // bank                  Bank           @relation(fields: [bankId], references: [id])
  // bankId                String?
  expectedBankAccount   BankAccount?   @relation(fields: [expectedBankAccountId], references: [id])
  expectedBankAccountId String?
  remark                String?
  isFullyPaid           Boolean        @default(false)
  isPartiallyPaid       Boolean        @default(false)
  isFullyApproved       Boolean        @default(false)
  isPartiallyApproved   Boolean?       @default(false)
  isEnabled             Boolean        @default(true)
  enableRemark          String?
  enabledBy             User?          @relation("EnabledBy", fields: [enabledById], references: [id])
  enabledById           String?
  disableRemark         String?
  disabledBy            User?          @relation("DisabledBy", fields: [disabledById], references: [id])
  disabledById          String?
  disabledDate          DateTime?
  status                OrderStatus    @default(PENDING_APPROVAL)
  lastApprovedDate      DateTime?
  isPartiallyFulfilled  Boolean        @default(false)
  isFullyFulfilled      Boolean        @default(false)
  lastFulfilledDate     DateTime?
  isPartiallyShipped    Boolean        @default(false)
  isFullyShipped        Boolean        @default(false)
  orderNumber           Int            @default(0)
  OrderItem             OrderItem[]
  OrderPayment          OrderPayment[]
  // BankAccount           Bank?          @relation(fields: [bankId], references: [id])
  // bankId                String?
}

model OrderItem {
  id                    String                 @id @default(uuid())
  createdAt             DateTime               @default(now())
  orderQuantity         Int                    @default(0)
  purchasedQuantity     Int                    @default(0)
  isApproved            Boolean                @default(false)
  approvedBy            User?                  @relation("ApprovedBy", fields: [approvedById], references: [id])
  approvedById          String?
  approvedAt            DateTime?
  productVariant        ProductVariant         @relation(fields: [productVariantId], references: [id])
  productVariantId      String
  isEnabled             Boolean                @default(true)
  enableRemark          String?
  enabledBy             User?                  @relation("EnabledBy", fields: [enabledById], references: [id])
  enabledById           String?
  disableRemark         String?
  disabledBy            User?                  @relation("DisabledBy", fields: [disabledById], references: [id])
  disabledById          String?
  disabledDate          DateTime?
  productVariantPrice   ProductVariantPrice    @relation(fields: [productVariantPriceId], references: [id])
  productVariantPriceId String
  order                 Order                  @relation(fields: [orderId], references: [id])
  orderId               String
  price                 Float
  currency              String
  isPartiallyFulfilled  Boolean                @default(false)
  fulfilledQuantity     Int                    @default(0)
  isFullyFulfilled      Boolean                @default(false)
  isPartiallyShipped    Boolean                @default(false)
  shippedQuantity       Int                    @default(0)
  isFullyShipped        Boolean                @default(false)
  OrderItemFulfillment  OrderItemFulfillment[]
  // OrderItemTransactionDetail OrderItemTransactionDetail[]
}

model OrderPayment {
  id            String    @id @default(uuid())
  createdAt     DateTime  @default(now())
  order         Order     @relation(fields: [orderId], references: [id])
  orderId       String
  paidAmount    Float
  isEnabled     Boolean   @default(true)
  enableRemark  String?
  enabledBy     User?     @relation("EnabledBy", fields: [enabledById], references: [id])
  enabledById   String?
  disableRemark String?
  disabledBy    User?     @relation("DisabledBy", fields: [disabledById], references: [id])
  disabledById  String?
  disabledDate  DateTime?
  payment       Payment   @relation(fields: [paymentId], references: [id])
  paymentId     String
}

model Payment {
  id               String         @id @default(uuid())
  createdAt        DateTime       @default(now())
  amount           Float
  unassignedAmount Float?
  isEnabled        Boolean        @default(true)
  enableRemark     String?
  enabledBy        User?          @relation("EnabledBy", fields: [enabledById], references: [id])
  enabledById      String?
  disableRemark    String?
  disabledBy       User?          @relation("DisabledBy", fields: [disabledById], references: [id])
  disabledById     String?
  disabledDate     DateTime?
  paymentOption    PaymentOption  @relation(fields: [paymentOptionId], references: [id])
  paymentOptionId  String
  // bank                  Bank?          @relation(fields: [bankId], references: [id])
  // bankId                String?
  bankAccount      BankAccount?   @relation(fields: [bankAccountId], references: [id])
  bankAccountId    String?
  referenceNumber  String?
  receiptNumber    String?
  customer         Customer       @relation(fields: [customerId], references: [id])
  customerId       String
  // OrderPayment          OrderPayment[]
  OrderPayment     OrderPayment[]
}

model OrderItemFulfillment {
  id                String         @id @default(uuid())
  createdAt         DateTime       @default(now())
  orderItem         OrderItem      @relation(fields: [orderItemId], references: [id])
  orderItemId       String
  stock             Stock          @relation(fields: [stockId], references: [id])
  stockId           String
  fulfilledQuantity Int
  shippedQuantity   Int            @default(0)
  isEnabled         Boolean        @default(true)
  enableRemark      String?
  enabledBy         User?          @relation("EnabledBy", fields: [enabledById], references: [id])
  enabledById       String?
  disableRemark     String?
  disabledBy        User?          @relation("DisabledBy", fields: [disabledById], references: [id])
  disabledById      String?
  disabledDate      DateTime?
  ShipmentItem      ShipmentItem[]
}

model ShipmentStatusOption {
  id             String           @id @default(uuid())
  createdAt      DateTime         @default(now())
  title          String
  abbreviation   String?
  description    String?
  isEnabled      Boolean          @default(true)
  enableRemark   String?
  enabledBy      User?            @relation("EnabledBy", fields: [enabledById], references: [id])
  enabledById    String?
  disableRemark  String?
  disabledBy     User?            @relation("DisabledBy", fields: [disabledById], references: [id])
  disabledById   String?
  disabledDate   DateTime?
  ShipmentStatus ShipmentStatus[]
}

model ShipmentItemStatusOption {
  id                 String               @id @default(uuid())
  createdAt          DateTime             @default(now())
  title              String
  abbreviation       String?
  description        String?
  isEnabled          Boolean              @default(true)
  enableRemark       String?
  enabledBy          User?                @relation("EnabledBy", fields: [enabledById], references: [id])
  enabledById        String?
  disableRemark      String?
  disabledBy         User?                @relation("DisabledBy", fields: [disabledById], references: [id])
  disabledById       String?
  disabledDate       DateTime?
  ShipmentItemStatus ShipmentItemStatus[]
}

model CarrierType {
  id            String    @id @default(uuid())
  createdAt     DateTime  @default(now())
  title         String
  abbreviation  String?
  description   String?
  isEnabled     Boolean   @default(true)
  enableRemark  String?
  enabledBy     User?     @relation("EnabledBy", fields: [enabledById], references: [id])
  enabledById   String?
  disableRemark String?
  disabledBy    User?     @relation("DisabledBy", fields: [disabledById], references: [id])
  disabledById  String?
  disabledDate  DateTime?
  Carrier       Carrier[]
}

model Carrier {
  id            String      @id @default(uuid())
  createdAt     DateTime    @default(now())
  title         String
  identifier    String?
  description   String?
  carrierType   CarrierType @relation(fields: [carrierTypeId], references: [id])
  carrierTypeId String
  isEnabled     Boolean     @default(true)
  enableRemark  String?
  enabledBy     User?       @relation("EnabledBy", fields: [enabledById], references: [id])
  enabledById   String?
  disableRemark String?
  disabledBy    User?       @relation("DisabledBy", fields: [disabledById], references: [id])
  disabledById  String?
  disabledDate  DateTime?
  Shipment      Shipment[]
}

model Shipment {
  id                    String           @id @default(uuid())
  createdAt             DateTime         @default(now())
  type                  ShipmentType     @default(ORDER)
  carrier               Carrier          @relation(fields: [carrierId], references: [id])
  carrierId             String
  fromLocation          Location?        @relation("ShipmentFromLocation", fields: [fromLocationId], references: [id])
  fromLocationId        String?
  toLocation            Location?        @relation("ShipmentToLocation", fields: [toLocationId], references: [id])
  toLocationId          String?
  isEnabled             Boolean          @default(true)
  enableRemark          String?
  enabledBy             User?            @relation("EnabledBy", fields: [enabledById], references: [id])
  enabledById           String?
  disableRemark         String?
  disabledBy            User?            @relation("DisabledBy", fields: [disabledById], references: [id])
  disabledById          String?
  disabledDate          DateTime?
  shipmentNumber        String
  note                  String?
  shipmentScheduledDate DateTime
  isShipmentStarted     Boolean          @default(false)
  shipmentStartDate     DateTime?
  shipmentStartedBy     User?            @relation("StartedBy", fields: [shipmentStartedById], references: [id])
  shipmentStartedById   String?
  isShipmentLoaded      Boolean          @default(false)
  shipmentLoadedDate    DateTime?
  shipmentLoadedBy      User?            @relation("LoadedBy", fields: [shipmentLoadedById], references: [id])
  shipmentLoadedById    String?
  isShipmentArrived     Boolean          @default(false)
  expectedArrivalDate   DateTime?
  actualArrivalDate     DateTime?
  arrivalConfirmedBy    User?            @relation("ArrivalConfirmedBy", fields: [arrivalConfirmedById], references: [id])
  arrivalConfirmedById  String?
  isShipmentCompleted   Boolean          @default(false)
  shipmentCompletedDate DateTime?
  shipmentCompletedBy   User?            @relation("CompletedBy", fields: [shipmentCompletedById], references: [id])
  shipmentCompletedById String?
  shipmentItems         ShipmentItem[]
  ShipmentStatus        ShipmentStatus[]
}

model ShipmentItem {
  id                     String                @id @default(uuid())
  createdAt              DateTime              @default(now())
  shipment               Shipment              @relation(fields: [shipmentId], references: [id])
  shipmentId             String
  orderItemFulfillment   OrderItemFulfillment? @relation(fields: [orderItemFulfillmentId], references: [id])
  orderItemFulfillmentId String?
  stock                  Stock?                @relation(fields: [stockId], references: [id])
  stockId                String?
  quantity               Int
  isEnabled              Boolean               @default(true)
  enableRemark           String?
  enabledBy              User?                 @relation("EnabledBy", fields: [enabledById], references: [id])
  enabledById            String?
  disableRemark          String?
  disabledBy             User?                 @relation("DisabledBy", fields: [disabledById], references: [id])
  disabledById           String?
  disabledDate           DateTime?
  ShipmentItemStatus     ShipmentItemStatus[]
}

model ShipmentStatus {
  id            String               @id @default(uuid())
  createdAt     DateTime             @default(now())
  shipment      Shipment             @relation(fields: [shipmentId], references: [id])
  shipmentId    String
  status        ShipmentStatusOption @relation(fields: [statusId], references: [id])
  statusId      String
  isEnabled     Boolean              @default(true)
  enableRemark  String?
  enabledBy     User?                @relation("EnabledBy", fields: [enabledById], references: [id])
  enabledById   String?
  disableRemark String?
  disabledBy    User?                @relation("DisabledBy", fields: [disabledById], references: [id])
  disabledById  String?
  disabledDate  DateTime?
}

model ShipmentItemStatus {
  id             String                   @id @default(uuid())
  createdAt      DateTime                 @default(now())
  shipmentItem   ShipmentItem             @relation(fields: [shipmentItemId], references: [id])
  shipmentItemId String
  status         ShipmentItemStatusOption @relation(fields: [statusId], references: [id])
  statusId       String
  isEnabled      Boolean                  @default(true)
  enableRemark   String?
  enabledBy      User?                    @relation("EnabledBy", fields: [enabledById], references: [id])
  enabledById    String?
  disableRemark  String?
  disabledBy     User?                    @relation("DisabledBy", fields: [disabledById], references: [id])
  disabledById   String?
  disabledDate   DateTime?
}

